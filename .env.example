# Prisme.ai API Configuration

# Your Prisme.ai API Bearer token
PRISME_API_KEY=your_bearer_token_here

# Your Prisme.ai workspace ID (default workspace)
PRISME_WORKSPACE_ID=your_workspace_id_here

# Prisme.ai API base URL (default: https://api.staging.prisme.ai/v2)
PRISME_API_BASE_URL=https://api.staging.prisme.ai/v2

# Optional: Workspace name mappings (JSON format)
# Allows you to reference workspaces by friendly names instead of IDs
# Example: PRISME_WORKSPACES={"prod":"wks_123abc","staging":"wks_456def","dev":"wks_789ghi"}
# PRISME_WORKSPACES={"prod":"wks_123abc","staging":"wks_456def"}

# Multi-environment setups are configured in $PRISME_CONFIG_DIR/config.json.
# Tokens are registered with:
#   node "<plugin>/build/index.js" set-token <environment> --api-url <api-url> --config-dir "$PRISME_CONFIG_DIR"
# Common API URLs:
#   sandbox: https://api.sandbox.prisme.ai/v2
#   prod:    https://api.studio.prisme.ai/v2

# Optional: Default environment name (default: "default")
# When tools use workspaceName without environment parameter, this environment will be used
# PRISME_DEFAULT_ENVIRONMENT=sandbox

# Optional: Force readonly mode (blocks all write operations)
# When set to "true", only readonly tools will be available
# Useful for production environments or read-only access scenarios
# PRISME_FORCE_READONLY=true

# Optional: Disable feedback/reporting tools
# When set to "true", feedback tools (report_issue_or_feedback, update_report, get_reports) are hidden
# Use this if you prefer no data to be sent to Prisme.ai servers
# PRISME_DISABLE_FEEDBACK_TOOLS=true
