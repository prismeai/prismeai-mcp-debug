{
  "name": "prisme-ai-builder",
  "version": "2.0.1",
  "description": "MCP server for Prisme.ai AI Builder API",
  "type": "module",
  "main": "plugin/build/index.js",
  "scripts": {
    "preinstall": "cd linter && npm install",
    "build": "cd linter && npm run build && cd .. && tsc",
    "build:bundle": "cd linter && npm run build && cd .. && node scripts/bundle.mjs",
    "start": "node plugin/build/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "prisme-ai",
    "ai-builder",
    "automation"
  ],
  "author": "Prisme.ai",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.5",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
