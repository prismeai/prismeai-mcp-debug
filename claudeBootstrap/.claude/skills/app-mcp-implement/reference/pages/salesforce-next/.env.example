# Your Prisme.ai API URL — MUST include the /v2 suffix.
# Self-hosted example:  https://api.acme.example.com/v2
# Public sandbox:       https://api.sandbox.prisme.ai/v2
PRISMEAI_API_URL=

# Personal access token (recommended) — mint one in your platform UI under
# Settings → Access Tokens (/settings/tokens). Token format: at:<uuid>.
# User-scoped, revocable, has explicit expiry.
PRISMEAI_ACCESS_TOKEN=

# OR (legacy) — org-scoped API key created in the AI Governance app → API Keys.
# Use ONE of PRISMEAI_ACCESS_TOKEN or PRISMEAI_API_KEY. Access token is preferred.
# PRISMEAI_API_KEY=

# Workspace ID where the bundle will be deployed (the short ID, e.g. B4eoHS6).
PRISMEAI_WORKSPACE_ID=

# Your Prisme.ai platform UI URL (where end users browse, e.g. https://app.acme.example.com).
# Optional: only required to upload embed.js for 3rd-party `<script>` embedding.
# Leave blank to skip embed.js upload.
PRISMEAI_PLATFORM_URL=

# Optional: bundle key. Defaults to the workspace slug returned by the API.
# Override only if you publish multiple bundles to the same workspace.
# PRISMEAI_BUNDLE_SLUG=

# Optional: app version label written to workspace.config.value.bundles[slug].version
PRISMEAI_APP_VERSION=1.0.0

# For multi-env, copy this file to .env.<name> and pick at deploy time:
#   npm run deploy -- --env=staging
#   PRISMEAI_ENV=production npm run release

# Optional: skip steps you don't need
# PRISMEAI_SKIP_AUTOMATIONS_SYNC=true  # don't push automations/*
# PRISMEAI_SKIP_SOURCE_SYNC=true       # don't push src/* into the workspace
# PRISMEAI_SKIP_BUNDLE_CLEANUP=true    # keep orphan bundle.js/embed.js files
# PRISMEAI_SKIP_VERSION_SNAPSHOT=true  # don't POST /workspaces/:id/versions
